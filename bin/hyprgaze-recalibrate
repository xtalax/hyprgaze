#!/usr/bin/env bash
# Stop the daemon (if running), run full calibration, restart if it was running.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"

was_active=0
if systemctl --user is-active --quiet hyprgaze.service; then
    was_active=1
    systemctl --user stop hyprgaze.service
fi

notify-send -t 3000 -a hyprgaze "hyprgaze" "Starting calibration — face each dot" \
    2>/dev/null || true

set +e
"$REPO/.venv/bin/hyprgaze" calibrate > /tmp/hyprgaze-recal.log 2>&1
rc=$?
set -e

if [ "$rc" -eq 0 ]; then
    notify-send -t 3000 -a hyprgaze "hyprgaze" "Calibration complete" 2>/dev/null || true
else
    notify-send -t 6000 -a hyprgaze "hyprgaze" \
        "Calibration failed — see /tmp/hyprgaze-recal.log" 2>/dev/null || true
fi

if [ "$was_active" = "1" ]; then
    systemctl --user start hyprgaze.service
fi
exit "$rc"
